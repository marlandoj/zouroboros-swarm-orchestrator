#!/bin/bash
# Swarm Orchestrator CLI Wrapper

set -e
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

show_help() {
    cat << 'EOF'
Swarm Orchestrator v4 - Multi-Agent Execution Engine

USAGE:
    swarm run <tasks.json> [options]     Execute swarm with task file
    swarm doctor                         Run health checks

OPTIONS:
    --swarm-id <id>           Unique swarm identifier
    --strategy <type>         Memory strategy: none|sliding|hierarchical|sequential
    --concurrency <n>         Max parallel API agents
    --local-concurrency <n>   Max parallel local executors
    --timeout <seconds>       Per-task timeout
    --model <name>            Model name for API calls
    --dag-mode <mode>         streaming|waves
    --no-memory               Disable memory systems

EXAMPLES:
    swarm run examples/sample-tasks.json --swarm-id my-project
    swarm doctor

EOF
}

case "${1:-help}" in
    run)
        shift
        bun "$SCRIPT_DIR/orchestrate-v4.ts" "$@"
        ;;
    doctor)
        bun "$SCRIPT_DIR/orchestrate-v4.ts" doctor
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        echo "Unknown command: $1"
        show_help
        exit 1
        ;;
esac
